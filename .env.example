AUTH_TOKEN=your-secret-token-here
OPENAI_API_KEY=sk-...           # 语音功能所需（可选）
DATABASE_URL=sqlite+aiosqlite:///./claude_manager.db
WORKSPACE_DIR=~/Projects
CLAUDE_BINARY=claude
CODEX_BINARY=codex
DEFAULT_PROVIDER=claude         # claude | codex
PROVIDER_OPTIONS=claude,codex
DEFAULT_CODEX_MODEL=gpt-5.5
CODEX_MODEL_OPTIONS=default,gpt-5.5
AUTO_START_DISPATCHER=true
MERGE_PUSH_RETRIES=3
AUTO_PUSH_TO_ORIGIN=true
PORT=8000                       # 主服务端口（默认 8000）

# ── Worker（分布式执行）──────────────────────────────────────────────
WORKER_SSH_KEY_PATH=~/.ssh/ccm_worker_key  # Manager→Worker SSH 私钥路径（setup.sh 自动生成）

# ── 数据库自动备份（可选，BACKUP_ENABLED=true 时生效）──────────────────────────
BACKUP_ENABLED=false
BACKUP_TYPE=local               # local | s3 | oss
BACKUP_INTERVAL_SECONDS=3600   # 备份间隔（秒），默认 1 小时
BACKUP_MAX_COPIES=10           # 保留的最大备份份数
BACKUP_TEMP_DIR=               # 归档临时目录（避免占满 /tmp），例如 /home/ubuntu/.cache/claude-manager-backup-tmp

# local 后端（BACKUP_TYPE=local）
BACKUP_DESTINATION_PATH=        # 备份目标目录，例如 /mnt/backup/claude-manager（使用绝对路径，~ 会自动展开）

# AWS S3 后端（BACKUP_TYPE=s3）
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# 阿里云 OSS 后端（BACKUP_TYPE=oss）
BACKUP_OSS_ENDPOINT=            # 例如 oss-cn-hangzhou.aliyuncs.com
BACKUP_OSS_BUCKET=
BACKUP_OSS_ACCESS_KEY=
BACKUP_OSS_SECRET_KEY=
