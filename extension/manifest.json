{
  "manifest_version": 3,
  "name": "CCM Quick Capture",
  "version": "1.0.0",
  "description": "Screenshot & create tasks in Claude Code Manager",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://xiaoyu.claude-code-manager.com/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
